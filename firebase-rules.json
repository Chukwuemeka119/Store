{
  "rules": {
    "businesses": {
      "$bid": {
        ".read": true,
        ".write": true,
        "config": {
          ".read": true,
          ".write": true,
          "adminPassword": {
            ".read": false,
            ".write": true
          }
        },
        "business": { ".read": true, ".write": true },
        "cashiers": { ".read": true, ".write": true },
        "inventory": {
          ".read": true,
          ".write": true,
          "$itemId": {
            ".validate": "newData.hasChildren(['name','price','qty']) && newData.child('price').isNumber() && newData.child('price').val() >= 0 && newData.child('qty').isNumber() && newData.child('qty').val() >= 0"
          }
        },
        "sales": { ".read": true, ".write": true }
      }
    },
    "directory": {
      ".read": true,
      ".write": true
    },
    "analytics": {
      ".read": false,
      ".write": true
    },
    "ownerConfig": {
      ".read": false,
      ".write": false,
      "password": {
        ".read": false,
        ".write": true
      }
    }
  }
}
